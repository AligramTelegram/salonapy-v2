// Prisma Schema - Hemensalon v2

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  BASLANGIC
  PROFESYONEL
  ISLETME
}

enum AppointmentStatus {
  BEKLIYOR
  ONAYLANDI
  TAMAMLANDI
  IPTAL
  GELMEDI
}

enum NotificationChannel {
  SMS
  EMAIL
}

enum NotificationStatus {
  BEKLIYOR
  GONDERILDI
  BASARISIZ
}

enum TransactionType {
  GELIR
  GIDER
}

model Tenant {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  phone         String?
  email         String?
  address       String?
  logo          String?
  plan          Plan     @default(BASLANGIC)
  planStartedAt DateTime @default(now())
  planEndsAt    DateTime?
  isActive      Boolean  @default(true)
  smsUsed             Int      @default(0)
  smsCredits          Int      @default(0)
  smsResetAt          DateTime @default(now())
  appointmentsUsed    Int      @default(0)
  appointmentsResetAt DateTime @default(now())
  waUsed         Int      @default(0)
  sms24hReminder Boolean  @default(true)
  sms1hReminder  Boolean  @default(true)
  country       String   @default("TR")
  currency      String   @default("TRY")
  timezone      String   @default("Europe/Istanbul")

  // İşletme sahibi / Fatura bilgileri (İyzico alıcı bilgileri için kullanılır)
  ownerName     String?
  ownerPhone    String?
  ownerEmail    String?
  ownerIdNumber String?  // TC Kimlik No veya Pasaport No
  ownerAddress  String?
  ownerCity     String?
  taxNumber     String?  // Vergi numarası
  taxOffice     String?  // Vergi dairesi

  // WhatsApp AI Paketi
  whatsappAIEnabled     Boolean   @default(false)
  whatsappAIStartedAt   DateTime?
  whatsappAIEndsAt      DateTime?
  whatsappMessagesUsed  Int       @default(0)
  whatsappMessagesLimit Int       @default(500)

  // Instagram AI Paketi
  instagramAIEnabled     Boolean   @default(false)
  instagramAIStartedAt   DateTime?
  instagramAIEndsAt      DateTime?
  instagramMessagesUsed  Int       @default(0)
  instagramMessagesLimit Int       @default(500)

  onboardingCompleted Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users            User[]
  staff            Staff[]
  services         Service[]
  customers        Customer[]
  appointments     Appointment[]
  transactions     Transaction[]
  notifications    Notification[]
  subscription     Subscription?
  packages         Package[]
  customerPackages CustomerPackage[]
  announcementDismissals AnnouncementDismissal[]
  supportTickets         SupportTicket[]
  invoices               Invoice[]
  integrations           Integration[]
  aiSettings             AISettings?
  conversations          Conversation[]

  @@map("tenants")
}

enum UserRole {
  OWNER
  ADMIN
  USER
}

model User {
  id         String   @id @default(cuid())
  tenantId   String
  supabaseId String   @unique
  email      String   @unique
  name       String
  role       UserRole @default(OWNER)
  avatarUrl  String?
  createdAt  DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Staff {
  id           String   @id @default(cuid())
  tenantId     String
  supabaseId   String?  @unique
  name         String
  phone        String?
  email        String   @unique
  avatarUrl    String?
  slug         String   @unique
  title        String?
  bio          String?
  color        String   @default("#7c3aed")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services     Service[]
  appointments Appointment[]
  workHours    StaffWorkHours[]

  @@map("staff")
}

model StaffWorkHours {
  id        String  @id @default(cuid())
  staffId   String
  dayOfWeek Int
  startTime String
  endTime   String
  isWorking Boolean @default(true)

  staff     Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@map("staff_work_hours")
}

model Service {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  duration    Int
  price       Float
  color       String   @default("#7c3aed")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff        Staff[]
  appointments Appointment[]
  packages     Package[]

  @@map("services")
}

model Customer {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  phone       String
  email       String?
  notes       String?
  totalVisits Int       @default(0)
  totalSpent  Float     @default(0)
  lastVisitAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  packages      CustomerPackage[]
  conversations Conversation[]

  @@unique([tenantId, phone])
  @@map("customers")
}

model Appointment {
  id                 String            @id @default(cuid())
  tenantId           String
  staffId            String
  serviceId          String
  customerId         String
  customerPackageId  String?
  usedPackageSession Boolean           @default(false)
  date               DateTime
  startTime          String
  endTime            String
  status             AppointmentStatus @default(BEKLIYOR)
  notes              String?
  price              Float
  paid               Boolean           @default(false)
  hasBeenCompleted   Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff           Staff            @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service         Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerPackage CustomerPackage? @relation(fields: [customerPackageId], references: [id])
  notifications   Notification[]

  @@map("appointments")
}

model Package {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  serviceId   String
  sessions    Int
  price       Float
  validDays   Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service          Service           @relation(fields: [serviceId], references: [id])
  customerPackages CustomerPackage[]

  @@map("packages")
}

model CustomerPackage {
  id                String    @id @default(cuid())
  tenantId          String
  customerId        String
  packageId         String
  totalSessions     Int
  usedSessions      Int       @default(0)
  remainingSessions Int
  purchaseDate      DateTime  @default(now())
  expiryDate        DateTime?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  package      Package       @relation(fields: [packageId], references: [id])
  appointments Appointment[]

  @@map("customer_packages")
}

model Transaction {
  id          String          @id @default(cuid())
  tenantId    String
  type        TransactionType
  amount      Float
  category    String
  description String?
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Notification {
  id            String              @id @default(cuid())
  tenantId      String
  appointmentId String?
  channel       NotificationChannel
  to            String
  message       String
  status        NotificationStatus  @default(BEKLIYOR)
  sentAt        DateTime?
  errorMessage  String?
  createdAt     DateTime            @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@map("notifications")
}

model Subscription {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  plan            Plan
  amount          Float
  currency        String
  paymentProvider String
  paymentId       String?
  status          String   @default("ACTIVE")
  startDate       DateTime @default(now())
  endDate         DateTime
  autoRenew       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String    @db.Text
  coverImage  String?
  author      String    @default("Hemensalon")
  published   Boolean   @default(false)
  publishedAt DateTime?
  tags        String[]
  seo         Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  category    String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("site_settings")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model Announcement {
  id         String    @id @default(cuid())
  title      String
  content    String    @db.Text
  type       String    @default("INFO") // INFO | WARNING | SUCCESS
  isActive   Boolean   @default(true)
  targetPlan String?   // null = tüm planlar, veya plan key (BASLANGIC, vs.)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  dismissals AnnouncementDismissal[]

  @@map("announcements")
}

model AnnouncementDismissal {
  id             String   @id @default(cuid())
  announcementId String
  tenantId       String
  dismissedAt    DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([announcementId, tenantId])
  @@map("announcement_dismissals")
}

model Invoice {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  amount      Float?
  pdfUrl      String
  issuedAt    DateTime @default(now())
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model SupportTicket {
  id           String   @id @default(cuid())
  tenantId     String
  subject      String
  message      String   @db.Text
  status       String   @default("OPEN") // OPEN | IN_PROGRESS | CLOSED
  priority     String   @default("NORMAL") // LOW | NORMAL | HIGH
  adminReply   String?  @db.Text
  repliedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("support_tickets")
}

model Integration {
  id                 String    @id @default(cuid())
  tenantId           String
  platform           String    // WHATSAPP, INSTAGRAM
  enabled            Boolean   @default(true)
  status             String    @default("PENDING") // PENDING, ACTIVE, ERROR
  credentials        Json?
  phoneNumberId      String?
  instagramAccountId String?
  webhookVerified    Boolean   @default(false)
  lastSyncAt         DateTime?
  errorMessage       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, platform])
  @@index([tenantId])
  @@map("integrations")
}

model AISettings {
  id                 String  @id @default(cuid())
  tenantId           String  @unique
  enabled            Boolean @default(true)
  provider           String  @default("anthropic")
  model              String  @default("claude-sonnet-4-6")
  temperature        Float   @default(0.7)
  whatsappAutoReply  Boolean @default(true)
  whatsappAutoBook   Boolean @default(false)
  whatsappPrompt     String? @db.Text
  instagramAutoReply Boolean @default(true)
  instagramAutoBook  Boolean @default(false)
  instagramPrompt    String? @db.Text
  workingHoursStart  String  @default("09:00")
  workingHoursEnd    String  @default("18:00")
  outOfHoursMessage  String? @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("ai_settings")
}

model Conversation {
  id             String   @id @default(cuid())
  tenantId       String
  platform       String   // WHATSAPP, INSTAGRAM
  platformUserId String
  customerId     String?
  status         String   @default("ACTIVE") // ACTIVE, RESOLVED, ARCHIVED
  lastMessageAt  DateTime @default(now())
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer  Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  messages  Message[]

  @@unique([tenantId, platform, platformUserId])
  @@index([tenantId])
  @@index([customerId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  direction      String   // INBOUND, OUTBOUND
  content        String   @db.Text
  contentType    String   @default("TEXT")
  aiGenerated    Boolean  @default(false)
  intent         String?
  metadata       Json?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("messages")
}
